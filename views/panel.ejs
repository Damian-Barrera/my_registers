<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
    />
    <link rel="stylesheet" href="/estilos/main.css" />
    <link rel="stylesheet" href="/estilos/panel.css" />
    <title>Panel</title>
  </head>
  <body>
    <main class="main">
      <header>
        <div class="icon-solid">
          <i class="fa-solid fa-users"></i>
        </div>
        <h2>Panel de Administración</h2>
        <p>
          Bienvenido al panel de administración. Aqui podra gestionar su panel
        </p>
      </header>
      <section class="cards-container">
        <div class="card-title">
          <h3>Rutas</h3>
        </div>
        <div class="cards">

          <a href="/dashboard" class="card">
            <div class="icon-container">
              <i class="fa-solid fa-table"></i>
            </div>
            <div class="descripcion">
              <h4>Dashboard</h4>
              <p>Visualiza tus contactos</p>
            </div>
          </a>


          <a href="" class="card">
            <div class="icon-container">
              <i class="fa-solid fa-user-plus"></i>
            </div>
            <div class="descripcion">
              <h4>Agregar Contacto</h4>
              <p>Desde aquí puedes agregar nuevos contactos</p>
            </div>
          </a>


          <a href="" class="card">
            <div class="icon-container">
              <i class="fa-solid fa-user"></i>
            </div>
            <div class="descripcion">
              <h4>Perfiles</h4>
              <p>Aqui encontraras la informacion de tus perfiles</p>
            </div>
          </a>


          <a href="" class="card">
            <div class="icon-container">
              <i class="fa-solid fa-user-pen"></i>
            </div>
            <div class="descripcion">
              <h4>Editar Perfiles</h4>
              <p>Desde aquí puedes editar la información de tus perfiles</p>
            </div>
          </a>
        
        </div>
      </section>
    </main>
  </body>
</html>
