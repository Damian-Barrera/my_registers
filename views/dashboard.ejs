<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
    />
    <link rel="stylesheet" href="/estilos/main.css" />
    <link rel="stylesheet" href="/estilos/dashboard.css" />

    <title>Dashboard</title>
  </head>
  <body>
    <div class="main">
      <nav>
        <header class="header">
          <i class="fa-solid fa-users"></i>
          <h3>Panel de Control</h3>
        </header>
        <hr />
        <ul>
          <li>
            <a href="">
              <i class="fa-solid fa-users"></i>
              <span>Ver Contactos</span>
            </a>
          </li>
          <li>
            <a href="">
              <i class="fa-solid fa-user-plus"></i>
              <span>Agregar Contacto</span>
            </a>
          </li>
        </ul>

        <footer>
          <i class="fa-regular fa-user"></i>
          <div class="logout">
            <p>Cerrar Sesión</p>
            <span>@correoelectronico</span>
          </div>
          <a href="/">
            <i class="fa-solid fa-arrow-right-from-bracket"></i>
          </a>
        </footer>
      </nav>
      <section class="main-content">
        <header>
          <h2>Directorio</h2>
          <form class="search">
            <label for="">
              <i class="fa-solid fa-magnifying-glass"></i>
            </label>
            <input type="search" name="" placeholder="Buscar por nombre" />
          </form>
        </header>
        <div class="cards-images">
          <div class="img">
            <a href="/profile">
              <img src="/images/1080w.webp" alt="" />
              <span class="name-model">Renata</span>
            </a>
          </div>
          <div class="img">
            <a href="">
              <img src="/images/antomansilla.png" alt="" />
              <span class="name-model" >Anto</span>
            </a>
          </div>
          <div class="img">
            <a href="">
              <img src="/images/briza.jpg" alt="" />
              <span class="name-model">Briza</span>
            </a>
          </div>
         
          <div class="img">
            <a href="">
              <img src="/images/jessica.jpg" alt="" />
              <span class="name-model">Jessica</span>
            </a>
          </div>
          <div class="img">
            <a href="">
              <img src="/images/nina.jpg" alt="" />
