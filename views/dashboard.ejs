            </a>
          </div>
          <div class="img">
            <a href="">
              <img src="/images/anto.jpg" alt="" />
              <span class="name-model">Anto</span>
            </a>
          </div>
          <div class="img">
            <a href="">
              <img src="/images/renata.webp" alt="" />
              <span class="name-model">Renata</span>
            </a>
          </div>
          <div class="img">
            <a href="">
              <img src="/images/brizaa.jpg" alt="" />
